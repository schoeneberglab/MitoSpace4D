#!/bin/bash

#SBATCH --job-name=encode_data
#SBATCH --output autoencoder/runs/%x/%j.out
#SBATCH --error  autoencoder/runs/%x/%j.err
#SBATCH --partition=ghx4
#SBATCH --account=begq-dtai-gh
#SBATCH --nodes=1
#SBATCH --gpus-per-node=4
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=96
#SBATCH --time=24:00:00
#SBATCH --exclusive
#SBATCH --mem=0

srun python -m autoencoder.encode_data